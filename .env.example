# Server
SERVER_PORT=8080
ENV=development

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/auth_db?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=dev-access-secret-change-in-prod
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-prod
JWT_REFRESH_EXPIRY=168h

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/callback/google

# TOTP
TOTP_ENCRYPTION_KEY=00000000000000000000000000000000
TOTP_ISSUER=AuthService

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Rate Limiting
RATE_LIMIT_LOGIN=5-M
RATE_LIMIT_GLOBAL=100-M
